# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/.open-next/
/.wrangler/
.open-next-inner-build

# cloudflare local secrets
.dev.vars

# production
/build

# database (local only — regenera com npm run db:setup)
*.db
*.db-journal
/prisma/dev.db

# prisma client (regenera com npm install → postinstall)
/src/generated/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# uploads (logos)
/public/uploads/*
!/public/uploads/.gitkeep

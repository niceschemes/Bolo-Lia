{
  "name": "nework",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "build:cf": "opennextjs-cloudflare build",
    "start": "next start -p 3001",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:cf": "opennextjs-cloudflare build && wrangler pages deploy .open-next --project-name=bolo-lia",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:demo-photos": "tsx scripts/seed-demo-photos.ts",
    "db:setup": "prisma migrate dev && prisma db seed",
    "d1:migrate": "powershell -Command \"Get-ChildItem prisma/migrations -Directory | Sort-Object Name | ForEach-Object { npx wrangler d1 execute bolo-lia-db --remote --file=(Join-Path $_.FullName 'migration.sql') }\"",
    "d1:seed": "wrangler d1 execute bolo-lia-db --remote --file=prisma/d1-seed.sql",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@opennextjs/cloudflare": "^1.19.11",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-d1": "^7.8.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vercel/blob": "^2.4.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "jose": "^6.2.3",
    "next": "16.2.9",
    "pix-utils": "^2.8.2",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "wrangler": "^4.103.0"
  }
}
